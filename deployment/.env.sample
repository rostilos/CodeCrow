# Shared production secrets required by Docker Compose.
INTERNAL_API_SECRET=secret-change-me
QDRANT_API_KEY=change-me-to-a-random-qdrant-secret
POSTGRES_PASSWORD=change-me-to-a-random-postgres-password
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_TO_A_STRONG_PGADMIN_PASSWORD

# Optional values with Docker Compose fallbacks.
# POSTGRES_DB=codecrow_ai
# POSTGRES_USER=codecrow_user
# PGADMIN_DEFAULT_EMAIL=pgadmin@localhost
# GITHUB_REPOSITORY_OWNER=rostilos

# Optional production host-port overrides.
# Development compose has its own fallback ports when these remain unset.
# PGADMIN_HOST_PORT=5050
# RAG_PIPELINE_HOST_PORT=8001
# INFERENCE_ORCHESTRATOR_HOST_PORT=8000
