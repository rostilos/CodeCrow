# CodeCrow inference-orchestrator environment template.
# Required production values are active. Optional values that have code
# fallbacks are commented and show the effective default.

# === Service-to-Service Auth (required in production) ===
# Must match SERVICE_SECRET on rag-pipeline. Leave empty only for local dev.
# Avoid ${...} sequences because python-dotenv may interpolate them.
SERVICE_SECRET=change-me-to-a-random-secret

# === HTTP and Queue Runtime ===
# AI_CLIENT_HOST=0.0.0.0
# AI_CLIENT_PORT=8000
# REDIS_URL=redis://localhost:6379/1
# MAX_CONCURRENT_REVIEWS=4
# MAX_CONCURRENT_COMMANDS=10
# COMMAND_TIMEOUT_SECONDS=600
# REVIEW_TIMEOUT_SECONDS=1500
# REVIEW_GLOBAL_RAG_QUERY_TIMEOUT_SECONDS=5
# Exact-head AGENTIC archives are exchanged on the shared ephemeral path set
# once in deployment/.env as AGENTIC_WORKSPACE_ROOT.
# AGENTIC_WORKSPACE_TTL_SECONDS=21600

# === MCP Runtime ===
# MCP_SERVER_JAR=/app/codecrow-vcs-mcp-1.0.jar
# PLATFORM_MCP_JAR=/app/codecrow-platform-mcp-1.0.jar
# Optional remote-debug port; unset by default.
# MCP_DEBUG_PORT=5005
# MCP_POOL_SIZE=5
# MCP_POOL_MAX_REQUESTS=100
# MCP_POOL_MAX_AGE=3600
# MCP_POOL_ACQUIRE_TIMEOUT=30
# CODECROW_API_URL=http://codecrow-web-application:8081
# Normally injected by Docker Compose when internal Platform API auth is enabled.
# INTERNAL_API_SECRET=

# Allow OpenAI-compatible endpoints on private/link-local networks.
# Keep false unless the configured endpoint is trusted.
# ALLOW_PRIVATE_ENDPOINTS=false

# === LLM Defaults ===
# LLM_TEMPERATURE=0.0
# GEMINI_THINKING_LEVEL=low

# === Diff Processing Limits ===
# DIFF_MAX_FILE_SIZE=25600
# DIFF_MAX_FILES=400
# DIFF_MAX_TOTAL_SIZE=1000000
# DIFF_MAX_LINES_PER_FILE=3000

# === RAG Client and Reranking ===
# RAG_ENABLED=true
# RAG_API_URL=http://rag-pipeline:8001
# Alternative outbound RAG auth secret when SERVICE_SECRET is not used.
# CODECROW_RAG_API_SECRET=
# RAG_MIN_RELEVANCE_SCORE=0.7
# RAG_DEFAULT_TOP_K=15
# RAG_CACHE_TTL_SECONDS=300
# RAG_CACHE_MAX_SIZE=100
# LLM_RERANK_ENABLED=false
# LLM_RERANK_THRESHOLD=5
# LLM_RERANK_MAX_ITEMS=15
# QA documentation currently has a dedicated RAG endpoint override.
# RAG_PIPELINE_URL=http://rag-pipeline:8020
# REVIEW_DUPLICATION_RAG_MAX_QUERIES=8
# REVIEW_DUPLICATION_RAG_QUERY_CONCURRENCY=8
# REVIEW_DUPLICATION_RAG_QUERY_TIMEOUT_SECONDS=5.0

# === Review Pipeline ===
# REVIEW_INTERNAL_PR_INDEX_ENABLED=true
# REVIEW_VERIFICATION_ENABLED=true
# REVIEW_VERIFICATION_MAX_TOOL_ROUNDS=4
# REVIEW_SEMANTIC_RAG_FILLER_ENABLED=true
# REVIEW_DUPLICATION_RAG_ENABLED=true
# REVIEW_STAGE1_MAX_FILES_PER_BATCH=7
# REVIEW_STAGE1_BATCH_TOKEN_BUDGET=60000
# REVIEW_STAGE1_DIFF_CHUNK_TOKEN_BUDGET=35000
# REVIEW_STAGE1_MAX_CURRENT_FILE_CHARS=12000
# REVIEW_STAGE1_MAX_PARALLEL=5
# REVIEW_SEMANTIC_RAG_TIMEOUT_SECONDS=5
# REVIEW_GLOBAL_RAG_FALLBACK_TIMEOUT_SECONDS=5
# REVIEW_DETERMINISTIC_RAG_MAX_CHUNKS=80
# REVIEW_DEDUP_MAX_PARALLEL=4
# REVIEW_STRUCTURED_OUTPUT_ENABLED=true
# REVIEW_CLOUDFLARE_STRUCTURED_OUTPUT_ENABLED=false

# Small/medium review classification and Stage 2 policy.
# REVIEW_FAST_CHECK_ENABLED=true
# REVIEW_STAGE_2_ENABLED=true
# REVIEW_FAST_CHECK_MAX_FILES=4
# REVIEW_FAST_CHECK_MAX_CHANGED_LINES=800
# REVIEW_FAST_CHECK_MAX_DIFF_BYTES=120000
# REVIEW_MEDIUM_MAX_FILES=15
# REVIEW_MEDIUM_MAX_CHANGED_LINES=3000
# REVIEW_MEDIUM_MAX_DIFF_BYTES=450000
# REVIEW_FAST_CHECK_DEDUP_MAX_ISSUES=5

# === Stage Output Caps ===
# Set a cap to 0 to disable it. Canonical names contain STAGE_0/STAGE_1/etc.;
# legacy aliases without the underscore (STAGE0/STAGE1/etc.) are also accepted.
# REVIEW_OUTPUT_CAPS_ENABLED=true
# REVIEW_OUTPUT_CAP_MODEL_KWARG=
# REVIEW_STAGE_0_SMALL_MAX_OUTPUT_TOKENS=6000
# REVIEW_STAGE_0_MEDIUM_MAX_OUTPUT_TOKENS=8000
# REVIEW_STAGE_0_LARGE_MAX_OUTPUT_TOKENS=12000
# REVIEW_STAGE_1_SMALL_MAX_OUTPUT_TOKENS=20000
# REVIEW_STAGE_1_MEDIUM_MAX_OUTPUT_TOKENS=30000
# REVIEW_STAGE_1_LARGE_MAX_OUTPUT_TOKENS=40000
# REVIEW_VERIFICATION_SMALL_MAX_OUTPUT_TOKENS=5000
# REVIEW_VERIFICATION_MEDIUM_MAX_OUTPUT_TOKENS=8000
# REVIEW_VERIFICATION_LARGE_MAX_OUTPUT_TOKENS=12000
# REVIEW_STAGE_2_SMALL_MAX_OUTPUT_TOKENS=11000
# REVIEW_STAGE_2_MEDIUM_MAX_OUTPUT_TOKENS=18000
# REVIEW_STAGE_2_LARGE_MAX_OUTPUT_TOKENS=25000
# REVIEW_DEDUP_SMALL_MAX_OUTPUT_TOKENS=3000
# REVIEW_DEDUP_MEDIUM_MAX_OUTPUT_TOKENS=5000
# REVIEW_DEDUP_LARGE_MAX_OUTPUT_TOKENS=8000
# REVIEW_STAGE_3_SMALL_MAX_OUTPUT_TOKENS=8000
# REVIEW_STAGE_3_MEDIUM_MAX_OUTPUT_TOKENS=12000
# REVIEW_STAGE_3_LARGE_MAX_OUTPUT_TOKENS=18000

# Optional all-size overrides; unset by default so size-specific caps above apply.
# REVIEW_STAGE_0_MAX_OUTPUT_TOKENS=
# REVIEW_STAGE_1_MAX_OUTPUT_TOKENS=
# REVIEW_VERIFICATION_MAX_OUTPUT_TOKENS=
# REVIEW_STAGE_2_MAX_OUTPUT_TOKENS=
# REVIEW_DEDUP_MAX_OUTPUT_TOKENS=
# REVIEW_STAGE_3_MAX_OUTPUT_TOKENS=

# === Prompt Logging (Debug) ===
# PROMPT_LOG_ENABLED=false
# PROMPT_LOG_TO_FILE=false
# PROMPT_LOG_TO_CONSOLE=false
# PROMPT_LOG_DIR=/tmp/codecrow_prompts
# PROMPT_LOG_MAX_FILES=50

# === New Relic APM ===
# Set to the mounted config path to enable instrumentation; unset disables it.
# NEW_RELIC_CONFIG_FILE=/app/newrelic.ini
