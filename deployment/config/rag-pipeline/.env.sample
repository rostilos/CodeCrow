# CodeCrow rag-pipeline environment template.
# Required production values are active. Optional values that have code
# fallbacks are commented and show the effective default.

# === Service-to-Service Auth (required in production) ===
# Must match SERVICE_SECRET on inference-orchestrator. Leave empty only for dev.
SERVICE_SECRET=change-me-to-a-random-secret

# Optional Java web-server settings poller. When URL is empty, local env values
# below are used without polling.
# CODECROW_WEB_SERVER_URL=
# CODECROW_INTERNAL_SECRET=

# === Embedding Provider ===
# Choose ollama or openrouter. OpenRouter requires OPENROUTER_API_KEY.
# EMBEDDING_PROVIDER=ollama

# Ollama defaults (used only when EMBEDDING_PROVIDER=ollama).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

# OpenRouter settings (API key required only when EMBEDDING_PROVIDER=openrouter).
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=qwen/qwen3-embedding-8b

# 0 auto-detects the dimension from the selected model.
# EMBEDDING_DIM=0

# === Embedding Request Tuning ===
# OLLAMA_BATCH_SIZE=100
# OLLAMA_TIMEOUT=120
# OLLAMA_MAX_CHARS=24000
# OLLAMA_MAX_RETRIES=3
# OLLAMA_RETRY_BASE_DELAY=1.0
# OPENROUTER_BATCH_SIZE=100
# OPENROUTER_TIMEOUT=300
# OPENROUTER_MAX_CHARS=24000

# === Qdrant Storage ===
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION_PREFIX=codecrow
# QDRANT_VECTORS_ON_DISK=true

# === Queue and Server Runtime ===
# REDIS_URL=redis://redis:6379/1
# MAX_CONCURRENT_RAG_JOBS=2
# UVICORN_WORKERS=4

# === Repository and API Safety Limits ===
# Root directory that repo_path arguments may resolve under.
# ALLOWED_REPO_ROOT=/tmp
# RAG_MAX_CHUNKS_PER_INDEX=1000000
# RAG_MAX_FILES_PER_INDEX=50000
# RAG_MAX_FILES_PER_REQUEST=500
# RAG_MAX_SNIPPETS_PER_REQUEST=50
# RAG_MAX_BRANCHES_PER_REQUEST=10
# RAG_MAX_IDENTIFIERS_PER_QUERY=100
# RAG_MAX_PARENT_CLASSES_PER_QUERY=20
# RAG_MAX_NAMESPACES_PER_QUERY=10
# RAG_FALLBACK_BRANCHES=main,master,develop
# RAG_EMBEDDING_SUPPORTS_INSTRUCTIONS=true

# === Retrieval Scoring ===
# RAG_MIN_RELEVANCE_SCORE=0.7
# RAG_MAX_SCORE_CAP=1.0
# RAG_BOOST_FUNCTIONS_CLASSES=1.1
# RAG_BOOST_FALLBACK=1.0
# RAG_BOOST_OVERSIZED=0.95
# RAG_BOOST_SIMPLIFIED=0.8
# RAG_DENSITY_THRESHOLD=0.1
# RAG_DENSITY_FLOOR=0.3
# RAG_ECOSYSTEM_MISMATCH_PENALTY=0.2
# RAG_MAX_CHUNKS_PER_SOURCE_FILE=2
# RAG_OVERSIZED_CHUNK_THRESHOLD=4000
# RAG_OVERSIZED_CHUNK_PENALTY=0.5
# RAG_MISSING_DENSITY_PENALTY=0.85
