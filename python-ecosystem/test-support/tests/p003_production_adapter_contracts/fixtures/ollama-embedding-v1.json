{
  "schema_version": "1.0",
  "provider": "embedding",
  "routes": [
    {
      "method": "GET",
      "path": "/api/tags",
      "response": {
        "status": 200,
        "headers": {
          "content-type": "application/json"
        },
        "body": {
          "models": [
            {
              "name": "offline-embedding"
            }
          ]
        }
      }
    },
    {
      "method": "POST",
      "path": "/api/embeddings",
