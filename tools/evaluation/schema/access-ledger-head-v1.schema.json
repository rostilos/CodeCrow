{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codecrow.dev/schema/access-ledger-head-v1.schema.json",
  "title": "CodeCrow evaluation access ledger head v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "eventCount", "eventHash"],
  "properties": {
    "schemaVersion": {"const": 1},
    "eventCount": {"type": "integer", "minimum": 1},
    "eventHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
