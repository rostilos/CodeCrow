{
  "$id": "https://codecrow.dev/schemas/quality-gates/trust-bundle-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "bundleId": {"const": "p0-07-quality-contract-v1"},
    "files": {
      "items": {"$ref": "#/$defs/file"},
      "minItems": 1,
      "type": "array"
    },
    "schemaVersion": {"const": 1}
  },
  "required": ["schemaVersion", "bundleId", "files"],
  "title": "CodeCrow protected quality-contract trust bundle v1",
  "type": "object",
  "$defs": {
    "file": {
      "additionalProperties": false,
      "properties": {
        "path": {"$ref": "#/$defs/repositoryPath"},
        "role": {"enum": ["implementation", "policy", "schema", "workflow", "runner"]},
        "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}
      },
      "required": ["path", "role", "sha256"],
      "type": "object"
    },
    "repositoryPath": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "type": "string"
    }
  }
}
